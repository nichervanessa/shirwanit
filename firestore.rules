// firestore.rules
// Deploy these rules in Firebase Console → Firestore → Rules
// or using: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Public invoices collection ─────────────────────────────────────────
    // Anyone can READ invoices (for verification)
    // Only authenticated users can CREATE/UPDATE (from the desktop app)
    match /invoices/{invoiceId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        // Allow public increment of verificationCount and lastVerifiedAt only
        || (request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['verificationCount', 'lastVerifiedAt']));
      allow delete: if request.auth != null;
    }

    // ── Stats (public read, server-only write) ─────────────────────────────
    match /stats/{statId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // ── User data (private — desktop app only) ─────────────────────────────
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
